    "@nestjs/platform-express": "^10.2.5",
    "@nestjs/swagger": "^7.2.1",
    "@okx-dex/okx-dex-sdk": "^1.0.11",
    "@raydium-io/raydium-sdk-v2": "^0.1.117-alpha",
    "@solana/spl-token": "^0.4.12",
    "@solana/web3.js": "^1.98.0",
    "axios": "^1.8.1",
    "axios-retry": "^4.5.0",
    "bignumber.js": "^9.1.2",
    "bs58": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "lossless-json": "^1.0.3",
